#!/bin/sh
# nerve — NerveOS CLI shim
# Provides user-facing commands: hive status, hive peers, hive join, etc.

NERVED_SOCK=/var/run/nerved.sock

case "$1" in
  status)
    echo "NerveOS nerved status:"
    # TODO: query nerved via unix socket / HTTP API
    systemctl status nerved 2>/dev/null || \
      start-stop-daemon --status --pidfile /var/run/nerved.pid && echo "running" || echo "stopped"
    ;;
  peers)
    echo "Hive peers:"
    wg show nerve0 peers 2>/dev/null || echo "(no WireGuard interface — is nerved running?)"
    ;;
  join)
    echo "Joining hive: $2"
    # TODO: contact bootstrap peer, exchange keys, update config
    echo "Not yet implemented — coming in nerved v0.2"
    ;;
  *)
    echo "Usage: hive {status|peers|join <bootstrap-addr>}"
    exit 1
    ;;
esac
