#!/bin/sh
# NerveOS daemon init script (SysV style)

DAEMON=/usr/bin/hived
PIDFILE=/var/run/hived.pid
CONFIG=/etc/hive/hived.conf

case "$1" in
  start)
    echo "Starting hived..."
    start-stop-daemon -S -b -p $PIDFILE -N -10 -x $DAEMON -- --config $CONFIG
    ;;
  stop)
    echo "Stopping hived..."
    start-stop-daemon -K -p $PIDFILE
    ;;
  restart)
    $0 stop
    sleep 1
    $0 start
    ;;
  *)
    echo "Usage: $0 {start|stop|restart}"
    exit 1
    ;;
esac

exit 0
