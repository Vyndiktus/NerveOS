# Reticulum Network Stack — NerveOS default configuration
# Location on device: /etc/reticulum/config
#
# Reticulum uses a custom TOML-like format.
# Full reference: https://reticulum.network/manual/

[reticulum]
  # Enable transport mode — this node will route packets for others
  enable_transport = True

  # Share the RNS instance with local processes via a socket
  share_instance = True
  shared_instance_port = 37428

  # Log level: 0=critical 2=error 3=warning 4=info 5=debug
  loglevel = 4

[interfaces]

  # ── Auto-discovery on all local IP interfaces ────────────────────
  # Discovers other RNS nodes on the same LAN/mesh via UDP multicast.
  # Works transparently over bat0 (batman-adv) — covers the entire mesh.
  [[NerveOS AutoInterface]]
    type = AutoInterface
    enabled = True
    group_id = nerveos          # isolates this hive from other RNS networks

  # ── BATMAN-adv mesh interface (explicit fallback) ─────────────────
  # If AutoInterface doesn't pick up bat0, bind directly.
  [[NerveOS Batman Interface]]
    type = AutoInterface
    enabled = True
    devices = bat0
    group_id = nerveos

  # ── TCP bootstrap (internet-wide hive connectivity) ───────────────
  # Connect to a known NerveOS bootstrap node for internet-wide discovery.
  # Leave disabled until a bootstrap server is deployed.
  [[NerveOS Bootstrap]]
    type = TCPClientInterface
    enabled = False
    target_host = bootstrap.nerveos.network
    target_port = 4242

  # ── LoRa interface (optional — hardware required) ─────────────────
  # Enable when a SX1276/SX1278 LoRa module is connected via SPI.
  # Provides ultra-long-range fallback at very low bandwidth (~1 kbps).
  [[NerveOS LoRa]]
    type = RNodeInterface
    enabled = False
    port = /dev/ttyUSB0
    frequency = 915000000      # 915 MHz (US ISM) — change for your region
    bandwidth = 125000
    txpower = 17
    spreadingfactor = 8
    codingrate = 5
