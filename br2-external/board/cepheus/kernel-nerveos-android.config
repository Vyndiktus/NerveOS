# NerveOS kernel config fragment — disables Qualcomm Android-specific drivers
# that fail to compile with modern GCC or are missing OSS headers.

# MDSS PLL trace: mdss_pll_trace.h missing from Xiaomi OSS release
CONFIG_QCOM_MDSS_PLL=n

# MSM remote debug: struct designated_init error with GCC 12+
CONFIG_MSM_RDBG=n

# STMicro fts_521 touchscreen: strict-prototypes errors (correct symbol)
CONFIG_TOUCHSCREEN_ST_FTS_V521=n

# Qualcomm GPU (Adreno/KGSL): kgsl_trace.h missing from OSS release
CONFIG_QCOM_KGSL=n

# HID QVR (Qualcomm VR): hid-trace.h missing, trace_qvr_recv_sensor undeclared
CONFIG_HID_QVR=n

# Qualcomm Spectra camera: cam_context.h missing from OSS release
CONFIG_SPECTRA_CAMERA=n

# SDE rotator (media) calls mdp_vbif_lock from DRM subsystem — cross-subsystem undefined ref
CONFIG_MSM_SDE_ROTATOR=n

# DRM/display: Qualcomm modified drm_sysfs.c + SDE stack have too many
# MSM-specific symbol dependencies. NerveOS is headless — no display needed.
CONFIG_DRM=n

# Qualcomm IPA (Internet Packet Accelerator): ipa_trace.h + rndis_ipa_trace.h missing
CONFIG_IPA3=n
CONFIG_RNDIS_IPA=n

# GSI (Generic Software Interface, IPA companion): linker relocation error with modern binutils
CONFIG_GSI=n

# IDT P9220 wireless charger: idtp9220.h missing from OSS release
CONFIG_IDT_P9220=n

# RELOCATABLE is a promptless bool — only selectable via RANDOMIZE_BASE.
# crDroid has RANDOMIZE_BASE=y (→ RELOCATABLE=y). With no kaslr-seed from ABL,
# KASLR picks offset=0 (no actual randomization) but the relocation infrastructure
# in head.S is active, allowing the kernel to survive any physical load address.
CONFIG_RANDOMIZE_BASE=y

# KALLSYMS_BASE_RELATIVE: promptless bool forced =n by patch 0006 (Bootlin toolchain
# produced out-of-range 32-bit relative offsets). Fragment line kept for documentation.
CONFIG_KALLSYMS_BASE_RELATIVE=n

# USB gadget — serial console (/dev/ttyGS0) and RNDIS network (debug initramfs)
CONFIG_USB_G_SERIAL=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_SERIAL=y
CONFIG_USB_CONFIGFS_ACM=y
CONFIG_USB_CONFIGFS_RNDIS=y
CONFIG_USB_F_RNDIS=y

# Qualcomm subsystem/PIL stack: PIL tries to load modem/ADSP firmware at boot.
# Without firmware blobs in initramfs these calls block indefinitely.
CONFIG_MSM_PIL=n
CONFIG_MSM_SUBSYSTEM_RESTART=n
CONFIG_MSM_SPCOM=n
CONFIG_MSM_BOOT_STATS=n

# UFS storage: SCSI_UFS_QCOM hangs during probe waiting for UFS device init.
# NerveOS boots from initramfs — no UFS needed at this stage.
CONFIG_SCSI_UFSHCD=n
CONFIG_SCSI_UFSHCD_PLATFORM=n
CONFIG_SCSI_UFS_QCOM=n
CONFIG_SCSI_UFS_QCOM_ICE=n
CONFIG_PHY_QCOM_UFS=n

# WiFi/WLAN subsystem: ICNSS tries to load WCN3990 firmware via QMI and waits
# for WiFi subsystem to come online. PIL is disabled so this hangs indefinitely.
CONFIG_ICNSS=n
CONFIG_ICNSS_QMI=n
CONFIG_CNSS_UTILS=n
CONFIG_CNSS_GENL=n
CONFIG_WCNSS_MEM_PRE_ALLOC=n

# PCIe / WCN3990 hardware: PCIe MSM driver tries to bring up PCIe link to WCN3990.
# MHI is the modem host interface over PCIe. Both hang without working hardware.
CONFIG_PCI_MSM=n
CONFIG_MHI_QCOM=n

# CDSP/ADSP firmware loaders: try to load DSP firmware, hang with PIL disabled.
CONFIG_MSM_CDSP_LOADER=n
CONFIG_MSM_SERVICE_LOCATOR=n

# QCOM_FORCE_WDOG_BITE_ON_PANIC: forces a hard watchdog bite (wipes DRAM) on panic.
# This is why panic=3 never produces a clean soft reboot and pstore is always empty.
CONFIG_QCOM_FORCE_WDOG_BITE_ON_PANIC=n
# DLOAD mode: intercepts panics and enters download mode instead of rebooting.
CONFIG_QCOM_DLOAD_MODE=n

# Video codec: needs firmware/hardware not available in headless boot.
CONFIG_MSM_VIDC_V4L2=n
CONFIG_MSM_VIDC_GOVERNORS=n

# RPMSG/GLINK: these wait for modem/ADSP to come online via shared memory.
# PIL is disabled so remote processors never start — these drivers hang.
CONFIG_RPMSG=n
CONFIG_RPMSG_CHAR=n
CONFIG_RPMSG_QCOM_GLINK_NATIVE=n
CONFIG_RPMSG_QCOM_GLINK_SMEM=n
CONFIG_RPMSG_QCOM_GLINK_SPSS=n
CONFIG_RPMSG_QCOM_GLINK_SPI=n
CONFIG_QCOM_GLINK=n
CONFIG_QCOM_GLINK_PKT=n
CONFIG_QCOM_BUS_CONFIG_RPMH=n

# Audio: SND_SOC stack depends on ADSP (via APR/GLINK). Headless — not needed.
CONFIG_SOUND=n
CONFIG_SND=n
CONFIG_SND_SOC=n

# NPU depends on cdsprm (CDSP runtime mgmt, needs GLINK to talk to CDSP).
CONFIG_MSM_NPU=n

# BT FM SLIM codec depends on SND_SOC.
CONFIG_BTFM_SLIM=n

# Lockup detector: fires softlockup panic after watchdog_thresh seconds if CPU stuck.
# Combined with softlockup_panic=1 in cmdline, gives us a stack trace via pstore.
CONFIG_LOCKUP_DETECTOR=y
CONFIG_SOFTLOCKUP_DETECTOR=y

# Hung task detector: fires panic if a task stays in TASK_UNINTERRUPTIBLE (D state)
# for > hung_task_timeout_secs. This catches drivers sleeping on hardware that never responds.
CONFIG_DETECT_HUNG_TASK=y
CONFIG_BOOTPARAM_HUNG_TASK_PANIC=y

# pstore/ramoops — logs kernel panic to oops partition, readable via fastboot
CONFIG_PSTORE=y
CONFIG_PSTORE_RAM=y
