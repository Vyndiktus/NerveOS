# NerveOS additions on top of sm8150-mainline base config

# WireGuard — built-in (not module) so it's available before rootfs mounts
CONFIG_WIREGUARD=y

# BATMAN-adv mesh transport
CONFIG_BATMAN_ADV=m
CONFIG_BATMAN_ADV_MCAST=y
CONFIG_MAC80211_MESH=y

# USB gadget serial (for debug console)
CONFIG_USB_CONFIGFS_ACM=y
CONFIG_USB_F_ACM=y

# No KASLR — required for our boot image format
CONFIG_RANDOMIZE_BASE=n
CONFIG_KALLSYMS_BASE_RELATIVE=n
