# NerveOS additions on top of sm8150-mainline base config

# Version string — must match Buildroot module directory (6.11.0-sm8150)
CONFIG_LOCALVERSION_AUTO=n

# WireGuard — module (loads from /lib/modules/6.11.0-sm8150/)
CONFIG_WIREGUARD=m

# BATMAN-adv mesh transport — built-in so it's available without module loading
CONFIG_BATMAN_ADV=y
CONFIG_BATMAN_ADV_MCAST=y
CONFIG_MAC80211_MESH=y

# USB gadget serial (for debug console)
CONFIG_USB_CONFIGFS_ACM=y
CONFIG_USB_F_ACM=y

# DRM/MSM display pipeline (SM8150 Adreno 640 + Samsung EA8076 AMOLED)
CONFIG_DRM=y
CONFIG_DRM_MSM=y
CONFIG_DRM_MSM_DSI=y
CONFIG_DRM_MSM_DSI_7NM_PHY=y
CONFIG_DRM_PANEL_SAMSUNG_SOFEF00=y
CONFIG_DRM_GEM_DMA_HELPER=y
CONFIG_DRM_GEM_SHMEM_HELPER=y

# WiFi — WCN3990 via ath10k SNOC
CONFIG_CFG80211=y
CONFIG_MAC80211=y
CONFIG_ATH10K=y
CONFIG_ATH10K_SNOC=y
CONFIG_ATH_COMMON=y

# Bluetooth — WCN3990 via HCI UART QCA
CONFIG_BT=y
CONFIG_BT_HCIUART=y
CONFIG_BT_HCIUART_QCA=y
CONFIG_BT_QCA=y

# Input subsystem — required by libinput for touch, keyboard, pointer
CONFIG_INPUT_EVDEV=y

# GPU buffer sync — required by Mesa/freedreno
CONFIG_SYNC_FILE=y
CONFIG_DMABUF_HEAPS=y
CONFIG_DMABUF_HEAPS_SYSTEM=y
CONFIG_DMABUF_HEAPS_CMA=y

# No KASLR — required for our boot image format
CONFIG_RANDOMIZE_BASE=n
CONFIG_KALLSYMS_BASE_RELATIVE=n

# Disable EFI — forces native ARM64 boot protocol so ABL passes our appended
# DTB (x3 register) instead of providing its own EFI DTB with UFS disabled.
CONFIG_EFI=n
CONFIG_EFI_STUB=n
CONFIG_TOUCHSCREEN_ST_FTS=n
