# HiveOS kernel config fragment — BATMAN-adv mesh networking
# Applied on top of the cepheus defconfig via BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES

CONFIG_BATMAN_ADV=m
CONFIG_BATMAN_ADV_BATMAN_V=y
CONFIG_BATMAN_ADV_DAT=y
CONFIG_BATMAN_ADV_NC=y
CONFIG_BATMAN_ADV_MCAST=y
CONFIG_BATMAN_ADV_DEBUGFS=n
CONFIG_BATMAN_ADV_TRACING=n

# 802.11s mesh point mode (needed for wireless batman-adv links)
CONFIG_MAC80211_MESH=y
