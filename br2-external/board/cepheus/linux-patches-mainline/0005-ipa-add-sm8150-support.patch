diff --git a/drivers/net/ipa/ipa_smp2p.c b/drivers/net/ipa/ipa_smp2p.c
index fcaadd111..703a60dde 100644
--- a/drivers/net/ipa/ipa_smp2p.c
+++ b/drivers/net/ipa/ipa_smp2p.c
@@ -218,6 +218,33 @@ static void ipa_smp2p_power_release(struct ipa *ipa)
 	ipa->smp2p->power_on = false;
 }
 
+/* Proactively tell the modem that IPA power is on.
+ * Called from SSR BEFORE_POWERUP — IPA runtime PM may show suspended but
+ * the driver is active; bypass pm_runtime_get_if_active() and force clock=ON. */
+void ipa_smp2p_notify_ap(struct ipa *ipa)
+{
+	struct ipa_smp2p *smp2p = ipa->smp2p;
+	u32 mask;
+
+	if (!smp2p || smp2p->notified)
+		return;
+
+	pr_err("ipa_smp2p_notify_ap: forcing ipa-clock-enabled=1 valid=1\n");
+
+	/* Signal IPA clock is on (bypass pm_runtime check — IPA driver is active) */
+	mask = BIT(smp2p->enabled_bit);
+	qcom_smem_state_update_bits(smp2p->enabled_state, mask, mask);
+
+	/* Signal the enabled bit is valid */
+	mask = BIT(smp2p->valid_bit);
+	qcom_smem_state_update_bits(smp2p->valid_state, mask, mask);
+
+	/* power_on=false: we bypassed pm_runtime, so power_release must not put an
+	 * uncounted reference. The SMP2P bits are already set correctly. */
+	smp2p->power_on = false;
+	smp2p->notified = true;
+}
